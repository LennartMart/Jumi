<?xml version="1.0" encoding="utf-8"?>
<extension type="plugin" group="system" method="upgrade">
    <name>plg_system_jumi</name>
    <author>Edvard Ananyan</author>
    <creationDate>2026</creationDate>
    <copyright>Copyright (C) 2026 LennartMart. All rights reserved.</copyright>
    <license>http://www.gnu.org/copyleft/gpl.html GNU/GPL</license>
    <authorEmail>info@2glux.com</authorEmail>
    <authorUrl>http://2glux.com</authorUrl>
    <version>4.0.0</version>
    <description>PLG_SYSTEM_JUMI_XML_DESCRIPTION</description>

    <namespace path="src">Jumi\Plugin\System\Jumi</namespace>

    <files>
        <folder plugin="jumi">services</folder>
        <folder>src</folder>
    </files>

    <languages>
        <language tag="en-GB">language/en-GB/plg_system_jumi.ini</language>
        <language tag="en-GB">language/en-GB/plg_system_jumi.sys.ini</language>
    </languages>

    <config>
        <fields name="params">
            <fieldset name="basic">
                <field
                    name="default_absolute_path"
                    type="text"
                    label="PLG_SYSTEM_JUMI_FIELD_ABSPATH_LABEL"
                    description="PLG_SYSTEM_JUMI_FIELD_ABSPATH_DESC"
                    filter="raw"
                    size="80"
                />
                <field
                    name="hide_code"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_SYSTEM_JUMI_FIELD_HIDECODE_LABEL"
                    description="PLG_SYSTEM_JUMI_FIELD_HIDECODE_DESC"
                    default="0"
                    filter="integer"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
                <field
                    name="nested_replace"
                    type="radio"
                    layout="joomla.form.field.radio.switcher"
                    label="PLG_SYSTEM_JUMI_FIELD_NESTED_LABEL"
                    description="PLG_SYSTEM_JUMI_FIELD_NESTED_DESC"
                    default="0"
                    filter="integer"
                >
                    <option value="0">JNO</option>
                    <option value="1">JYES</option>
                </field>
            </fieldset>
        </fields>
    </config>
</extension>
