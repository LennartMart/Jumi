<?xml version="1.0" encoding="utf-8"?>
<metadata>
    <layout title="COM_JUMI_APPLICATION_VIEW_DEFAULT_TITLE">
        <message>COM_JUMI_APPLICATION_VIEW_DEFAULT_DESC</message>
    </layout>

    <fields name="request">
