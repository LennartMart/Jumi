<?xml version="1.0" encoding="utf-8"?>
<form>
    <fieldset name="details">
        <field
            name="id"
            type="number"
            label="JGLOBAL_FIELD_ID_LABEL"
            default="0"
            class="readonly"
            readonly="true"
        />

        <field
            name="title"
            type="text"
            label="COM_JUMI_FIELD_TITLE_LABEL"
            required="true"
            size="60"
        />

        <field
            name="alias"
            type="text"
            label="JFIELD_ALIAS_LABEL"
            description="JFIELD_ALIAS_DESC"
            hint="JFIELD_ALIAS_PLACEHOLDER"
            size="60"
        />

        <field
            name="custom_script"
            type="textarea"
            label="COM_JUMI_FIELD_CUSTOM_SCRIPT_LABEL"
            description="COM_JUMI_FIELD_CUSTOM_SCRIPT_DESC"
            filter="raw"
            cols="80"
            rows="15"
        />

        <field
            name="path"
            type="text"
            label="COM_JUMI_FIELD_PATH_LABEL"
            description="COM_JUMI_FIELD_PATH_DESC"
            filter="raw"
            size="60"
        />

        <field
            name="published"
            type="list"
            label="JSTATUS"
            default="1"
        >
            <option value="1">JPUBLISHED</option>
            <option value="0">JUNPUBLISHED</option>
        </field>

        <field
            name="access"
            type="accesslevel"
            label="JFIELD_ACCESS_LABEL"
            default="1"
        />
    </fieldset>
</form>
